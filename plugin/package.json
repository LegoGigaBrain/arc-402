{
  "name": "@arc402/arc402",
  "version": "1.3.3",
  "description": "ARC-402 protocol as a native OpenClaw plugin — hire, deliver, compute, subscribe",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skill"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "arc402-cli": ">=1.0.0"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "@sinclair/typebox": "^0.34.0",
    "@walletconnect/sign-client": "^2.17.0",
    "@walletconnect/keyvaluestorage": "^1.1.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
