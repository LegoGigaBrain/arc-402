{
  "fuzzing": {
    "workers": 2,
    "workerResetLimit": 50,
    "timeout": 120,
    "testLimit": 10000,
    "callSequenceLength": 100,
    "corpusDirectory": "corpus",
    "coverageEnabled": true,
    "targetContracts": [
      "ServiceAgreementInvariants"
    ],
    "assertionTesting": {
      "enabled": true,
      "testViewMethods": false
    },
    "propertyTesting": {
      "enabled": true,
      "testPrefixes": [
        "echidna_"
      ]
    },
    "optimizationTesting": {
      "enabled": false,
      "testPrefixes": []
    }
  },
  "compilation": {
    "platform": "crytic-compile",
    "platformConfig": {
      "target": ".",
      "solcVersion": "",
      "exportDirectory": "",
      "args": [
        "--foundry-compile-all"
      ]
    }
  }
}